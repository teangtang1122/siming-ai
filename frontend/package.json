{
  "name": "siming-frontend",
  "private": true,
  "version": "3.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "architecture": "depcruise --config .dependency-cruiser.cjs src && node scripts/check-feature-boundaries.mjs",
    "duplicates": "jscpd src ../backend/app --config ../.jscpd.json",
    "api:generate": "node scripts/openapi-types.mjs",
    "api:check": "node scripts/openapi-types.mjs --check",
    "quality": "npm run architecture && npm run duplicates && npm run api:check",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/react": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "antd": "^5.14.0",
    "axios": "^1.18.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "vis-data": "^7.1.9",
    "vis-network": "^9.1.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jscpd": "^5.0.12",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
